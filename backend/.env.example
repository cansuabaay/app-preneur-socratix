DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/socratix
SECRET_KEY=change-this-secret-key

# If true, POST /auth/forgot-password returns resetToken in JSON (no e-mail). Set false in production.
PASSWORD_RESET_EXPOSE_TOKEN=true

# AI Devil's Advocate (OpenAI or OpenRouter-compatible)
AI_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini

# Optional: use OpenRouter instead of OpenAI
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1